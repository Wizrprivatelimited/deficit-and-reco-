    "import pandas as pd\n",
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "import time\n",
    "\n",
    "# === Load course links from Excel ===\n",
    "input_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\OneDrive - Eduvanz Financing Private Limited\\\\Desktop\\\\3RI_Courses_List (1).xlsx\"\n",
    "df_links = pd.read_excel(input_file)\n",
    "\n",
    "# === Define exclusion filters ===\n",
    "keywords_to_remove = ['frequently asked questions', 'data science online course certification']\n",
    "exclude_keywords = [\n",
    "    'about', 'Overview', 'feature', 'career', 'faq', 'why', 'who can apply',\n",
    "    'certification', 'trainer', 'placement', 'project', 'tools', 'benefits',\n",
    "    'introduction', 'exam', 'job', 'interview', 'support', 'Prerequisite'\n",
    "]\n",
    "\n",
    "all_courses = []\n",
    "\n",
    "def extract_syllabus_from_url(url):\n",
    "    try:\n",
    "        response = requests.get(url, timeout=15)\n",
    "        response.raise_for_status()\n",
    "        soup = BeautifulSoup(response.text, 'html.parser')\n",
    "\n",
    "        # === Remove FAQ/certification sections ===\n",
    "        for acc in soup.find_all('div', class_='eael-accordion-list'):\n",
    "            title_tag = acc.find_previous('span', class_='eael-accordion-tab-title')\n",
    "            if title_tag and any(kw in title_tag.get_text(strip=True).lower() for kw in keywords_to_remove):\n",
    "                acc.decompose()\n",
    "\n",
    "        for heading in soup.find_all(['h2', 'h3']):\n",
    "            heading_text = heading.get_text(strip=True).lower()\n",
    "            if any(kw in heading_text for kw in keywords_to_remove):\n",
    "                parent = heading.find_parent('div', class_='elementor-widget-wrap')\n",
    "                if parent:\n",
    "                    parent.decompose()\n",
    "\n",
    "        # === Extract course name ===\n",
    "        course_name = soup.title.get_text(strip=True).replace('| 3RI Technologies', '').strip()\n",
    "\n",
    "        titles = soup.find_all('span', class_='eael-accordion-tab-title')\n",
    "        contents = soup.find_all('div', class_='eael-accordion-content')\n",
    "\n",
    "        course_syllabus_blocks = []\n",
    "\n",
    "        for title_tag, content_div in zip(titles, contents):\n",
    "            module_title = title_tag.get_text(strip=True)\n",
    "            module_title_clean = module_title.lower()\n",
    "\n",
    "            # Keep only actual syllabus/module sections\n",
    "            if any(kw in module_title_clean for kw in exclude_keywords + keywords_to_remove):\n",
    "                continue\n",
    "            if not any(char.isalpha() for char in module_title_clean):\n",
    "                continue  # skip empty or non-informative titles\n",
    "\n",
    "            printed_strong_texts = set()\n",
    "            final_lines = []\n",
    "\n",
    "            for elem in content_div.find_all(['li', 'p'], recursive=True):\n",
    "                # Remove duplicates for <strong>/<b>\n",
    "                strong_texts = [s.get_text(strip=True) for s in elem.find_all(['strong', 'b'])]\n",
    "                for text in strong_texts:\n",
    "                    if text and text not in printed_strong_texts:\n",
    "                        final_lines.append(f\"- {text}\")\n",
    "                        printed_strong_texts.add(text)\n",
    "\n",
    "                full_text = elem.get_text(strip=True)\n",
    "                if full_text and full_text not in printed_strong_texts:\n",
    "                    final_lines.append(f\"- {full_text}\")\n",
    "\n",
    "            if final_lines:\n",
    "                syllabus_block = f\"{module_title}\\n\" + \"\\n\".join(final_lines)\n",
    "                course_syllabus_blocks.append(syllabus_block)\n",
    "\n",
    "        # Final clean syllabus output\n",
    "        full_syllabus = \"\\n\\n\".join(course_syllabus_blocks)\n",
    "\n",
    "        return {\n",
    "            \"Course Name\": course_name,\n",
    "            \"Course Link\": url,\n",
    "            \"Course Syllabus\": full_syllabus.strip()\n",
    "        }\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"❌ Failed to process {url}: {e}\")\n",
    "        return {\n",
