    "import pandas as pd\n",
    "from bs4 import BeautifulSoup\n",
    "\n",
    "# === Load HTML file ===\n",
    "html_path = \"C:\\\\Users\\\\taslim.siddiqui\\\\Downloads\\\\Data Science Online Training and Certification Course _ 3RI Technologies.html\"\n",
    "with open(html_path, 'r', encoding='utf-8') as file:\n",
    "    html_content = file.read()\n",
    "\n",
    "soup = BeautifulSoup(html_content, 'html.parser')\n",
    "\n",
    "# === Step 1: Remove unwanted sections ===\n",
    "keywords_to_remove = ['frequently asked questions', 'data science online course certification']\n",
    "\n",
    "accordion_lists = soup.find_all('div', class_='eael-accordion-list')\n",
    "for acc in accordion_lists:\n",
    "    title_tag = acc.find_previous('span', class_='eael-accordion-tab-title')\n",
    "    if title_tag and any(kw in title_tag.get_text(strip=True).lower() for kw in keywords_to_remove):\n",
    "        acc.decompose()\n",
    "\n",
    "for heading in soup.find_all(['h2', 'h3']):\n",
    "    heading_text = heading.get_text(strip=True).lower()\n",
    "    if any(kw in heading_text for kw in keywords_to_remove):\n",
    "        parent = heading.find_parent('div', class_='elementor-widget-wrap')\n",
    "        if parent:\n",
    "            parent.decompose()\n",
    "\n",
    "# === Step 2: Extract course info ===\n",
    "course_name = soup.title.get_text(strip=True).replace('| 3RI Technologies', '').strip()\n",
    "course_link = \"https://www.3ritechnologies.com/course/data-science-online-training/\"\n",
    "\n",
    "titles = soup.find_all('span', class_='eael-accordion-tab-title')\n",
    "contents = soup.find_all('div', class_='eael-accordion-content')\n",
    "\n",
    "exclude_keywords = ['about', 'overview', 'feature', 'career', 'faq', 'why', 'who can apply']\n",
    "\n",
    "course_syllabus_blocks = []\n",
    "\n",
    "for title_tag, content_div in zip(titles, contents):\n",
    "    module_title = title_tag.get_text(strip=True)\n",
    "\n",
    "    if any(kw in module_title.lower() for kw in exclude_keywords + keywords_to_remove):\n",
    "        continue\n",
    "\n",
    "    final_lines = []\n",
    "    printed_strong_texts = set()\n",
    "\n",
    "    for elem in content_div.find_all(['li', 'p'], recursive=True):\n",
    "        # Check for nested <strong>/<b> first\n",
    "        strong_texts_in_elem = set()\n",
    "        for strong_elem in elem.find_all(['strong', 'b']):\n",
    "            strong_text = strong_elem.get_text(separator=' ', strip=True)\n",
    "            if strong_text and strong_text not in printed_strong_texts:\n",
    "                final_lines.append(f\"- {strong_text}\")\n",
    "                printed_strong_texts.add(strong_text)\n",
    "                strong_texts_in_elem.add(strong_text)\n",
    "\n",
    "        # Then add the full text only if it's not exactly equal to already printed strong text\n",
    "        full_text = elem.get_text(separator=' ', strip=True)\n",
    "        if full_text and full_text not in printed_strong_texts:\n",
    "            if full_text not in strong_texts_in_elem:  # prevent re-adding the same line\n",
    "                final_lines.append(f\"- {full_text}\")\n",
    "\n",
    "    if final_lines:\n",
    "        syllabus_block = f\"{module_title}\\n\" + \"\\n\".join(final_lines)\n",
    "        course_syllabus_blocks.append(syllabus_block)\n",
    "\n",
    "# === Final Output ===\n",
    "full_course_syllabus = \"\\n\\n\".join(course_syllabus_blocks)\n",
    "\n",
    "# Save to Excel\n",
    "df = pd.DataFrame([{\n",
    "    \"Course Name\": course_name,\n",
    "    \"Course Link\": course_link,\n",
    "    \"Course Syllabus\": full_course_syllabus\n",
    "}])\n",
    "\n",
    "output_path = \"C:\\\\Users\\\\taslim.siddiqui\\\\Downloads\\\\3RI Technologies_course syllabus.xlsx\"\n",
    "df.to_excel(output_path, index=False)\n",
    "\n",
    "# === Print output to console ===\n",
    "print(\"✅ Final cleaned and deduplicated syllabus:\\n\")\n",
    "print(\"Course Name:\", course_name)\n",
    "print(\"Course Link:\", course_link)\n",
    "print(\"\\n--- Course Syllabus ---\\n\")\n",
    "print(full_course_syllabus)\n",
    "\n",
    "print(\"\\n✅ Also saved to:\")\n",
    "print(output_path)\n"
   ]
  },
