    "import pandas as pd\n",
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "import time\n",
    "\n",
    "# === Step 1: Read course links from Excel ===\n",
    "input_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\OneDrive - Eduvanz Financing Private Limited\\\\Desktop\\\\3RI_technology.xlsx\"\n",
    "df_links = pd.read_excel(input_file)\n",
    "course_urls = df_links['Course Link'].dropna().unique().tolist()\n",
    "\n",
    "# === Step 2: Keyword filters ===\n",
    "keywords_to_remove = ['frequently asked questions', 'data science online course certification']\n",
    "exclude_keywords = ['about', 'overview', 'feature', 'career', 'faq', 'why', 'who can apply']\n",
    "\n",
    "# === Step 3: Extract syllabus from a single course URL ===\n",
    "def extract_course_syllabus(url):\n",
    "    try:\n",
    "        headers = {'User-Agent': 'Mozilla/5.0'}\n",
    "        response = requests.get(url, headers=headers, timeout=30)\n",
    "        if response.status_code != 200:\n",
    "            return {\n",
    "                \"Course Name\": \"Request failed\",\n",
    "                \"Course Link\": url,\n",
    "                \"Course Syllabus\": f\"HTTP Error: {response.status_code}\"\n",
    "            }\n",
    "\n",
    "        soup = BeautifulSoup(response.text, 'html.parser')\n",
    "\n",
    "        # === Remove specific accordion blocks ===\n",
    "        accordion_lists = soup.find_all('div', class_='eael-accordion-list')\n",
    "        for acc in accordion_lists:\n",
    "            title_tag = acc.find_previous('span', class_='eael-accordion-tab-title')\n",
    "            if title_tag and any(kw in title_tag.get_text(strip=True).lower() for kw in keywords_to_remove):\n",
    "                acc.decompose()\n",
    "\n",
    "        # === Remove headings (like FAQ/Overview) ===\n",
    "        for heading in soup.find_all(['h2', 'h3']):\n",
    "            heading_text = heading.get_text(strip=True).lower()\n",
    "            if any(kw in heading_text for kw in keywords_to_remove):\n",
    "                parent = heading.find_parent('div', class_='elementor-widget-wrap')\n",
    "                if parent:\n",
    "                    parent.decompose()\n",
    "\n",
    "        # === Extract course title ===\n",
    "        course_name = soup.title.get_text(strip=True).replace('| 3RI Technologies', '').strip()\n",
    "\n",
    "        # === Collect all module title/content pairs ===\n",
    "        module_pairs = []\n",
    "\n",
    "        # (1) Accordion pairs\n",
    "        accordion_titles = soup.find_all('span', class_='eael-accordion-tab-title')\n",
    "        accordion_contents = soup.find_all('div', class_='eael-accordion-content')\n",
    "        for title_tag, content_div in zip(accordion_titles, accordion_contents):\n",
    "            module_pairs.append((title_tag.get_text(strip=True), content_div))\n",
    "\n",
    "        # (2) Toggle pairs\n",
    "        toggle_titles = soup.find_all('a', class_='elementor-toggle-title')\n",
    "        toggle_contents = soup.find_all('div', class_='elementor-tab-content')\n",
    "        for title_tag, content_div in zip(toggle_titles, toggle_contents):\n",
    "            module_pairs.append((title_tag.get_text(strip=True), content_div))\n",
    "\n",
    "        # === Extract syllabus content ===\n",
    "        syllabus_blocks = []\n",
    "\n",
    "        for module_title, content_div in module_pairs:\n",
    "            if any(kw in module_title.lower() for kw in exclude_keywords + keywords_to_remove):\n",
    "                continue\n",
    "\n",
    "            final_lines = []\n",
    "            printed_strong_texts = set()\n",
    "\n",
    "            for elem in content_div.find_all(['li', 'p'], recursive=True):\n",
    "                strong_texts_in_elem = set()\n",
