    "import pandas as pd\n",
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "import re\n",
    "import time\n",
    "\n",
    "input_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\OneDrive - Eduvanz Financing Private Limited\\\\Desktop\\\\3RI_technology.xlsx\"\n",
    "output_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\OneDrive - Eduvanz Financing Private Limited\\\\Desktop\\\\3RI_technology_OUTPUT.xlsx\"\n",
    "\n",
    "df_links = pd.read_excel(input_file)\n",
    "\n",
    "def clean_html_and_extract_syllabus(html_content):\n",
    "    soup = BeautifulSoup(html_content, 'html.parser')\n",
    "\n",
    "    # Remove FAQ and overview sections\n",
    "    keywords_to_remove = ['frequently asked questions', 'data science online course certification', 'faq', 'overview']\n",
    "    heading_keywords_to_remove = ['overview', 'faq', 'about', 'certification', 'who can apply', 'feature', 'career', 'why']\n",
    "\n",
    "    for heading in soup.find_all(['h2', 'h3']):\n",
    "        heading_text = heading.get_text(strip=True).lower()\n",
    "        if any(kw in heading_text for kw in heading_keywords_to_remove):\n",
    "            parent = heading.find_parent('div', class_='elementor-widget-wrap')\n",
    "            if parent:\n",
    "                parent.decompose()\n",
    "\n",
    "    for acc in soup.find_all('div', class_='eael-accordion-list'):\n",
    "        title_tag = acc.find_previous('span', class_='eael-accordion-tab-title')\n",
    "        if title_tag and any(kw in title_tag.get_text(strip=True).lower() for kw in keywords_to_remove):\n",
    "            acc.decompose()\n",
    "\n",
    "    syllabus_blocks = []\n",
    "\n",
    "    def extract_blocks(title_tags, content_tags):\n",
    "        for title_tag, content_div in zip(title_tags, content_tags):\n",
    "            module_title = title_tag.get_text(strip=True)\n",
    "            if any(kw in module_title.lower() for kw in heading_keywords_to_remove + keywords_to_remove):\n",
    "                continue\n",
    "\n",
    "            final_lines = []\n",
    "            printed_strong_texts = set()\n",
    "\n",
    "            for elem in content_div.find_all(['li', 'p'], recursive=True):\n",
    "                strong_texts_in_elem = set()\n",
    "                for strong_elem in elem.find_all(['strong', 'b']):\n",
    "                    strong_text = strong_elem.get_text(separator=' ', strip=True)\n",
    "                    if strong_text and strong_text not in printed_strong_texts:\n",
    "                        final_lines.append(f\"- {strong_text}\")\n",
    "                        printed_strong_texts.add(strong_text)\n",
    "                        strong_texts_in_elem.add(strong_text)\n",
    "\n",
    "                full_text = elem.get_text(separator=' ', strip=True)\n",
    "                if full_text and full_text not in printed_strong_texts:\n",
    "                    if full_text not in strong_texts_in_elem:\n",
    "                        final_lines.append(f\"- {full_text}\")\n",
    "\n",
    "            if final_lines:\n",
    "                syllabus_blocks.append(f\"{module_title}\\n\" + \"\\n\".join(final_lines))\n",
    "\n",
    "    # Accordion titles\n",
    "    extract_blocks(\n",
    "        soup.find_all('span', class_='eael-accordion-tab-title'),\n",
    "        soup.find_all('div', class_='eael-accordion-content')\n",
    "    )\n",
    "\n",
    "    # Toggle titles\n",
    "    extract_blocks(\n",
    "        soup.find_all('a', class_='elementor-toggle-title'),\n",
    "        soup.find_all('div', class_='elementor-tab-content')\n",
    "    )\n",
    "\n",
    "    return \"\\n\\n\".join(syllabus_blocks) if syllabus_blocks else None\n",
    "\n",
    "# === Loop through course URLs and extract content ===\n",
    "results = []\n",
    "\n",
    "for i, row in df_links.iterrows():\n",
    "    course_link = row.get('Course Link') or row.get('course link') or row.get('Link')\n",
    "    if not course_link or not isinstance(course_link, str) or not course_link.startswith(\"http\"):\n",
    "        results.append(None)\n",
    "        continue\n",
    "\n",
    "    try:\n",
    "        response = requests.get(course_link, timeout=30, headers={\"User-Agent\": \"Mozilla/5.0\"})\n",
    "        if response.status_code == 200:\n",
    "            cleaned_syllabus = clean_html_and_extract_syllabus(response.text)\n",
    "            results.append(cleaned_syllabus)\n",
    "        else:\n",
    "            results.append(None)\n",
    "    except Exception as e:\n",
    "        print(f\"Failed: {course_link}\\n{e}\")\n",
    "        results.append(None)\n",
    "\n",
    "# === Add extracted syllabus to DataFrame and save ===\n",
    "df_links[\"Course Syllabus\"] = results\n",
    "df_links.to_excel(output_file, index=False)\n",
    "\n",
    "print(\"✅ Syllabus extraction completed and saved to:\", output_file)\n"
   ]
  },
