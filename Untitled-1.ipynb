   "source": [
    "import pandas as pd\n",
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "import time\n",
    "\n",
    "# === Step 1: Unique 3RI Course URLs ===\n",
    "course_urls = list(set([\n",
    "    \"https://3ritechnologies.com/course/data-science-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/devops-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/devops-and-aws-certification-training/\",\n",
    "    \"https://3ritechnologies.com/course/mean-stack-training-in-pune/\",\n",
    "    \"https://3ritechnologies.com/course/mern-stack-training-in-pune/\",\n",
    "    \"https://3ritechnologies.com/course/angularjs-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/reactjs-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/devops-with-aws-training/\",\n",
    "    \"https://3ritechnologies.com/course/azure-devops-az-400-certification-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/selenium-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/selenium-with-python-training/\",\n",
    "    \"https://3ritechnologies.com/course/software-testing-training/\",\n",
    "    \"https://3ritechnologies.com/course/full-stack-python-web-developer-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/mean-stack-online-training-course/\",\n",
    "    \"https://3ritechnologies.com/course/mern-stack-online-training/\",\n",
    "    \"https://3ritechnologies.com/course/tableau-with-sql-and-dwh-concepts-training/\",\n",
    "    \"https://www.3ritechnologies.com/course/data-science-online-training/\",\n",
    "    \"https://www.3ritechnologies.com/course/angularjs-online-training/\",\n",
    "    \"https://www.3ritechnologies.com/course/mean-stack-online-training-course/\",\n",
    "    \"https://www.3ritechnologies.com/course/tableau-online-training-certification/\",\n",
    "    \"https://www.3ritechnologies.com/course/selenium-online-training/\",\n",
    "    \"https://www.3ritechnologies.com/course/full-stack-python-web-developer-online-training/\"\n",
    "]))\n",
    "\n",
    "# === Step 2: Keywords to remove sections ===\n",
    "accordion_remove_keywords = ['frequently asked questions', 'data science online course certification', 'certification', 'faq']\n",
    "heading_keywords_to_remove = ['overview', 'about', 'feature', 'career', 'why', 'who can apply', 'certification', 'faq']\n",
    "exclude_keywords = ['about', 'overview', 'feature', 'career', 'faq', 'why', 'who can apply']\n",
    "\n",
    "# === Step 3: Extraction Function ===\n",
    "def extract_course_syllabus(url):\n",
    "    try:\n",
    "        headers = {'User-Agent': 'Mozilla/5.0'}\n",
    "        response = requests.get(url, headers=headers, timeout=20)\n",
    "        if response.status_code != 200:\n",
    "            return None\n",
    "\n",
    "        soup = BeautifulSoup(response.text, 'html.parser')\n",
    "\n",
    "        # === Remove unwanted H2/H3 sections ===\n",
    "        for heading in soup.find_all(['h2', 'h3']):\n",
    "            heading_text = heading.get_text(strip=True).lower()\n",
    "            if any(kw in heading_text for kw in heading_keywords_to_remove):\n",
    "                parent = heading.find_parent('div', class_='elementor-widget-wrap')\n",
    "                if parent:\n",
    "                    parent.decompose()\n",
    "\n",
    "        # === Remove unwanted accordions ===\n",
    "        for acc in soup.find_all('div', class_='eael-accordion-list'):\n",
    "            title_tag = acc.find_previous('span', class_='eael-accordion-tab-title')\n",
    "            if title_tag and any(kw in title_tag.get_text(strip=True).lower() for kw in accordion_remove_keywords):\n",
    "                acc.decompose()\n",
    "\n",
    "        # === Extract Course Info ===\n",
    "        course_name = soup.title.get_text(strip=True).replace('| 3RI Technologies', '').strip()\n",
    "        titles = soup.find_all('span', class_='eael-accordion-tab-title')\n",
    "        contents = soup.find_all('div', class_='eael-accordion-content')\n",
    "\n",
    "        syllabus_blocks = []\n",
    "\n",
    "        for title_tag, content_div in zip(titles, contents):\n",
    "            module_title = title_tag.get_text(strip=True)\n",
    "            if any(kw in module_title.lower() for kw in exclude_keywords + accordion_remove_keywords):\n",
    "                continue\n",
    "\n",
    "            final_lines = []\n",
    "            printed_strong_texts = set()\n",
    "\n",
    "            for elem in content_div.find_all(['li', 'p'], recursive=True):\n",
    "                # Print <strong>/<b> only once\n",
    "                for strong_elem in elem.find_all(['strong', 'b']):\n",
    "                    strong_text = strong_elem.get_text(\" \", strip=True)\n",
    "                    if strong_text and strong_text not in printed_strong_texts:\n",
    "                        final_lines.append(f\"- {strong_text}\")\n",
    "                        printed_strong_texts.add(strong_text)\n",
    "\n",
    "                # Always print full <li>/<p> even if duplicate\n",
    "                full_text = elem.get_text(\" \", strip=True)\n",
    "                if full_text:\n",
    "                    final_lines.append(f\"- {full_text}\")\n",
    "\n",
    "            if final_lines:\n",
    "                syllabus_blocks.append(f\"{module_title}\\n\" + \"\\n\".join(final_lines))\n",
    "\n",
    "        return {\n",
    "            \"Course Name\": course_name,\n",
    "            \"Course Link\": url,\n",
    "            \"Course Syllabus\": \"\\n\\n\".join(syllabus_blocks) if syllabus_blocks else None\n",
    "        }\n",
    "\n",
    "    except Exception as e:\n",
    "        return {\n",
    "            \"Course Name\": \"Error\",\n",
    "            \"Course Link\": url,\n",
    "            \"Course Syllabus\": str(e)\n",
    "        }\n",
    "\n",
    "# === Step 4: Scrape All Courses ===\n",
    "all_data = []\n",
    "for i, link in enumerate(course_urls, 1):\n",
    "    print(f\"Scraping ({i}/{len(course_urls)}): {link}\")\n",
    "    result = extract_course_syllabus(link)\n",
    "    all_data.append(result)\n",
    "    time.sleep(2)\n",
    "\n",
    "# === Step 5: Save to Excel ===\n",
    "df = pd.DataFrame(all_data)\n",
    "output_path = r\"C:\\Users\\taslim.siddiqui\\Downloads\\3RI_Technologies_All_Courses_Syllabus.xlsx\"\n",
    "df.to_excel(output_path, index=False)\n",
    "\n",
    "print(f\"\\n✅ Done! Data saved to: {output_path}\")\n"
   ]
