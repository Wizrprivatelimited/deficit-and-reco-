    "import pandas as pd\n",
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "import time\n",
    "\n",
    "# === Load Excel with course links ===\n",
    "input_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\OneDrive - Eduvanz Financing Private Limited\\\\Desktop\\\\3RI_Courses_List (1).xlsx\"\n",
    "df_links = pd.read_excel(input_file)\n",
    "\n",
    "# Keywords to remove: FAQ, Overview, etc.\n",
    "accordion_remove_keywords = [\n",
    "    'overview', 'course overview', 'about', 'feature', 'who can apply',\n",
    "    'career', 'faq', 'certification', 'trainer', 'project', 'interview',\n",
    "    'placement', 'why choose', 'course highlights', 'what you’ll learn',\n",
    "    'what you will learn'\n",
    "]\n",
    "\n",
    "heading_keywords_to_remove = ['overview']\n",
    "\n",
    "all_courses = []\n",
    "\n",
    "def extract_syllabus_from_url(url):\n",
    "    try:\n",
    "        response = requests.get(url, timeout=15)\n",
    "        response.raise_for_status()\n",
    "        soup = BeautifulSoup(response.text, 'html.parser')\n",
    "\n",
    "        # Remove block with H2/H3 headings like \"Overview\"\n",
    "        for heading in soup.find_all(['h2', 'h3']):\n",
    "            text = heading.get_text(strip=True).lower()\n",
    "            if any(kw in text for kw in heading_keywords_to_remove):\n",
    "                parent = heading.find_parent('div', class_='elementor-widget-wrap')\n",
    "                if parent:\n",
    "                    parent.decompose()\n",
    "\n",
    "        # Remove accordion blocks with unwanted titles\n",
    "        for acc in soup.find_all('div', class_='eael-accordion-list'):\n",
    "            title_tag = acc.find_previous('span', class_='eael-accordion-tab-title')\n",
    "            if title_tag:\n",
    "                title_text = title_tag.get_text(strip=True).lower()\n",
    "                if any(kw in title_text for kw in accordion_remove_keywords):\n",
    "                    acc.decompose()\n",
    "\n",
    "        # Extract course name\n",
    "        course_name = soup.title.get_text(strip=True).replace('| 3RI Technologies', '').strip()\n",
    "\n",
    "        titles = soup.find_all('span', class_='eael-accordion-tab-title')\n",
    "        contents = soup.find_all('div', class_='eael-accordion-content')\n",
    "\n",
    "        syllabus_blocks = []\n",
    "\n",
    "        for title_tag, content_div in zip(titles, contents):\n",
    "            module_title = title_tag.get_text(strip=True).strip()\n",
    "            lines = []\n",
    "            for tag in content_div.find_all(['li', 'p', 'strong', 'b'], recursive=True):\n",
    "                text = tag.get_text(separator=' ', strip=True)\n",
    "                if text:\n",
    "                    lines.append(f\"- {text}\")\n",
    "\n",
    "            if lines:\n",
    "                block = f\"{module_title}\\n\" + \"\\n\".join(lines)\n",
    "                syllabus_blocks.append(block)\n",
    "\n",
    "        full_syllabus = \"\\n\\n\".join(syllabus_blocks)\n",
    "\n",
    "        # === Print result to console ===\n",
    "        print(\"\\n==============================\")\n",
    "        print(\"Course Name:\", course_name)\n",
    "        print(\"Course Link:\", url)\n",
    "        print(\"Course Syllabus:\\n\")\n",
    "        print(full_syllabus)\n",
    "        print(\"==============================\\n\")\n",
    "\n",
    "        return {\n",
    "            \"Course Name\": course_name,\n",
    "            \"Course Link\": url,\n",
    "            \"Course Syllabus\": full_syllabus\n",
    "        }\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"❌ Error for {url}: {e}\")\n",
    "        return {\n",
    "            \"Course Name\": \"Error\",\n",
    "            \"Course Link\": url,\n",
    "            \"Course Syllabus\": f\"Error: {e}\"\n",
    "        }\n",
    "\n",
    "# === Process each course link ===\n",
    "for idx, row in df_links.iterrows():\n",
    "    url = row['Course link']\n",
    "    print(f\"🔍 ({idx + 1}/{len(df_links)}) Processing: {url}\")\n",
    "    course_data = extract_syllabus_from_url(url)\n",
    "    all_courses.append(course_data)\n",
    "    time.sleep(1.5)\n",
    "\n",
    "# === Save all to Excel ===\n",
    "df_final = pd.DataFrame(all_courses)\n",
    "output_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\Downloads\\\\final_clean_syllabus_PRINTED.xlsx\"\n",
    "df_final.to_excel(output_file, index=False)\n",
    "\n",
    "print(f\"\\n✅ Cleaned course data saved to:\\n{output_file}\")\n"
   ]
  },
