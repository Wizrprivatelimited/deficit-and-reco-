    "import pandas as pd\n",
    "import re\n",
    "\n",
    "# Step 1: Load the Excel file (Update filename as needed)\n",
    "input_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\OneDrive - Eduvanz Financing Private Limited\\\\Desktop\\\\3RI_technology.xlsx\"\n",
    "output_file = \"C:\\\\Users\\\\taslim.siddiqui\\\\OneDrive - Eduvanz Financing Private Limited\\\\Desktop\\\\cleaned_syllabus.xlsx\"\n",
    "\n",
    "# Load the Excel file into a DataFrame\n",
    "df = pd.read_excel(input_file)\n",
    "\n",
    "# Step 2: Define the cleaning function\n",
    "def clean_syllabus(text):\n",
    "    if pd.isna(text):\n",
    "        return text\n",
    "\n",
    "    lines = text.splitlines()\n",
    "    cleaned_lines = []\n",
    "    seen_headers = set()\n",
    "\n",
    "    for line in lines:\n",
    "        match = re.match(r\"-\\s*\\d+\\.\\s+(.+)\", line.strip())\n",
    "        if match:\n",
    "            title = match.group(1).strip().lower()\n",
    "            if title in seen_headers:\n",
    "                continue  # Skip duplicate headers\n",
    "            seen_headers.add(title)\n",
    "        cleaned_lines.append(line)\n",
    "\n",
    "    return \"\\n\".join(cleaned_lines)\n",
    "\n",
    "# Step 3: Apply the cleaning function to the correct column\n",
    "# Update 'Syllabus' to your actual column name containing the course content\n",
    "df['Syllabus'] = df['Course Syllabus'].apply(clean_syllabus)\n",
    "\n",
    "# Step 4: Save the cleaned DataFrame back to Excel\n",
    "df.to_excel(output_file, index=False)\n",
    "print(f\"✅ Cleaned syllabus saved to '{output_file}'\")\n"
   ]
  },
