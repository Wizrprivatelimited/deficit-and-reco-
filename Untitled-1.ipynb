    "                syllabus.append(h4.get_text(strip=True))\n",
    "                # Add lesson-preview-titles under this section\n",
    "                for sibling in title_div.find_next_siblings():\n",
    "                    if sibling.name == \"div\" and \"tutor-course-title\" in sibling.get(\"class\", []):\n",
    "                        break  # Stop if next module starts\n",
    "                    for lesson in sibling.find_all(\"span\", class_=\"lesson-preview-title\"):\n",
